# ======================
# 数据库配置
# ======================
DATABASE_URL=postgresql+psycopg2://username:password@localhost:5432/customer_service
REDIS_URL=redis://localhost:6379/0

# ======================
# API 密钥配置
# ======================
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
ZHIPU_API_KEY=your-zhipu-api-key
DASHSCOPE_API_KEY=your-dashscope-api-key

# ======================
# 飞书推送配置
# ======================
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-token
FEISHU_APP_ID=your-app-id
FEISHU_APP_SECRET=your-app-secret

# ======================
# 支付配置
# ======================
ALIPAY_APP_ID=your-alipay-app-id
ALIPAY_PRIVATE_KEY=your-alipay-private-key
ALIPAY_PUBLIC_KEY=your-alipay-public-key
WECHAT_APP_ID=your-wechat-app-id
WECHAT_MCH_ID=your-wechat-mch-id
WECHAT_API_KEY=your-wechat-api-key

# ======================
# 应用配置
# ======================
SECRET_KEY=your-secret-key-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ENVIRONMENT=development
DEBUG=True

# ======================
# 向量数据库配置
# ======================
VECTOR_DB=chroma  # chroma 或 milvus
CHROMA_PERSIST_DIR=./data/chroma
MILVUS_HOST=localhost
MILVUS_PORT=19530

# ======================
# 邮件配置 (SMTP)
# ======================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@yourdomain.com

# ======================
# 质检配置
# ======================
QUALITY_INSPECTION_ENABLED=True
QUALITY_RESPONSE_TIME_THRESHOLD=5
QUALITY_MIN_RESPONSE_LENGTH=10
QUALITY_MAX_RESPONSE_LENGTH=2000
#QUALITY_BATCH_SCHEDULE=0 0 2 * *  # 每日2点批量质检(cron格式)
QUALITY_ALERT_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/your-quality-alert-webhook
# 如果未配置,将使用FEISHU_WEBHOOK_URL发送质检告警
